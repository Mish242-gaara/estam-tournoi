# Connection string Neon (Postgres serverless, gratuit)
# Récupérable sur https://neon.tech après création d'un projet,
# ou automatiquement si vous ajoutez l'intégration Neon depuis l'onglet Storage de Vercel.
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/estam?sslmode=require

# Code organisateur, utilisé UNIQUEMENT pour créer le tout premier compte administrateur
# (page /bootstrap-admin). Une fois ce compte créé, les connexions se font par email/mot de passe.
ADMIN_PIN=ESTAM2026

# Clé secrète utilisée pour signer les sessions de connexion (cookies).
# Générez une valeur aléatoire longue, par exemple avec : openssl rand -base64 32
JWT_SECRET=remplacez_moi_par_une_longue_chaine_aleatoire
