# Connection string Neon (Postgres serverless, gratuit)
# Récupérable sur https://neon.tech après création d'un projet,
# ou automatiquement si vous ajoutez l'intégration Neon depuis l'onglet Storage de Vercel.
DATABASE_URL=postgresql://user:password@ep-xxxx-xxxx.eu-central-1.aws.neon.tech/estam?sslmode=require

# Code organisateur pour activer le mode édition (CRUD) sur le site.
# Changez-le avant de déployer.
ADMIN_PIN=ESTAM2026
